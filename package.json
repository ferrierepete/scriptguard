{
  "name": "scriptguard",
  "version": "1.2.0",
  "description": "Security scanner for npm package lifecycle scripts — detect malicious postinstall, preinstall, and prepare scripts before they run",
  "main": "dist/index.js",
  "bin": {
    "scriptguard": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "npm",
    "security",
    "lifecycle",
    "scripts",
    "postinstall",
    "preinstall",
    "supply-chain",
    "audit",
    "scanner",
    "malware"
  ],
  "author": "Peter Ferriere",
  "license": "MIT",
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "acorn": "^8.11.3",
    "acorn-walk": "^8.3.2",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "ora": "^8.0.0",
    "p-throttle": "^6.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0",
    "vitest": "^1.3.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
